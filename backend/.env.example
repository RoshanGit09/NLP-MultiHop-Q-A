# FinTraceQA Backend — Environment Variables
# Copy this file to .env and fill in your values.

# ── Neo4j ─────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ── KG mode ───────────────────────────────────────────────────────────────
# Set to "true" to use the in-memory mock KG (for development / testing)
USE_MOCK_KG=false

# ── Server ────────────────────────────────────────────────────────────────
PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
